                  "pm.test(\"loser projection is consistent\", () => { const body = pm.response.json(); pm.expect(body.rating).to.eql(975); pm.expect(body.games_played).to.eql(1); pm.expect(body.wins).to.eql(0); pm.expect(body.losses).to.eql(1); });"
